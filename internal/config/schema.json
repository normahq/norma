{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["agents", "profiles", "budgets"],
  "properties": {
    "profile": {
      "type": "string"
    },
    "agents": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/agentConfig"
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/profileConfig"
      }
    },
    "budgets": {
      "type": "object",
      "required": ["max_iterations"],
      "additionalProperties": false,
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keep_last": {
          "type": "integer",
          "minimum": 1
        },
        "keep_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "agentConfig": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["generic_acp", "codex_acp", "opencode_acp", "gemini_acp", "copilot_acp", "pool"]
        },
        "cmd": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "extra_args": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "base_url": {
          "type": "string",
          "minLength": 1
        },
        "api_key": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "integer",
          "minimum": 1
        },
        "use_tty": {
          "type": "boolean"
        },
        "pool": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "generic_acp"
              }
            }
          },
          "then": {
            "required": ["cmd"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["codex_acp", "opencode_acp", "gemini_acp", "copilot_acp"]
              }
            }
          },
          "then": {
            "not": {
              "required": ["cmd"]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "pool"
              }
            }
          },
          "then": {
            "required": ["pool"]
          }
        }
      ]
    },
    "profileConfig": {
      "type": "object",
      "required": ["pdca"],
      "properties": {
        "pdca": {
          "type": "object",
          "required": ["plan", "do", "check", "act"],
          "additionalProperties": false,
          "properties": {
            "plan": {
              "type": "string",
              "minLength": 1
            },
            "do": {
              "type": "string",
              "minLength": 1
            },
            "check": {
              "type": "string",
              "minLength": 1
            },
            "act": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "planner": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
